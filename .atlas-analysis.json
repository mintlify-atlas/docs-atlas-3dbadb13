    "controllers.validators.is_valid_curp(curp: str) -> bool",
    "sat.catalogs.CatalogManager.update_doctype(doctype: str)",
    "ws_client.client.APIClient.stamp(cfdi: CFDI) -> dict",
    "ws_client.client.APIClient.cancel_cfdi(signing_certificate, cfdi, reason, substitute_uuid)",
    "ws_client.client.APIClient.get_status(cfdi: CFDI) -> CfdiStatus",
    "ws_client.client.APIClient.get_subscription() -> dict",
    "ws_client.models.CfdiStatus (dataclass with DocumentStatus, CancellableStatus, CancellationStatus enums)",
    "tasks.check_cancellation_status() [scheduler: hourly]",
    "Document event hooks: before_stamp_cfdi, after_stamp_cfdi"
  ]
